# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_USER=sales_user
DB_PASS=sales_pass
DB_NAME=sales_db
DB_HOST=localhost
DB_PORT=5432

# ─── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sales_user:sales_pass@localhost:5432/sales_db
# In Docker Compose, override to:
# DATABASE_URL=postgresql+asyncpg://sales_user:sales_pass@db:5432/sales_db

# ─── Frontend ─────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000/api/v1
# In Docker Compose, override to:
# API_BASE_URL=http://backend:8000/api/v1

# ─── Producer ─────────────────────────────────────────────────────────────────
API_URL=http://localhost:8000/api/v1/sales/ingest
